# Copy file ini menjadi backend/.env, lalu isi sesuai kebutuhan lokal/hosting.
# Jangan commit file backend/.env asli karena bisa berisi password database/API key.

# PostgreSQL lokal:
# DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:5432/mindtrack
# DATABASE_SSLMODE=disable

# Supabase/hosting PostgreSQL:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@HOST:6543/postgres
# DATABASE_SSLMODE=require

# Groq AI advice, opsional:
# GROQ_API_KEY=

# Admin monitoring, opsional. Kosongkan ADMIN_PASSWORD untuk menonaktifkan login admin.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
